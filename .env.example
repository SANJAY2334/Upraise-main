NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
SITE_URL=https://uprise.example.com

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uprise?schema=public

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Error tracking (optional — leave blank to disable)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Frontend API URL pointing to the Render backend (optional in dev, required in prod)
VITE_API_URL=
