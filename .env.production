# ─── APPLICATION CONTAINER CONFIGURATION ──────────────────────────────────────
NODE_ENV=production
PORT=4000

# Client access configurations
CLIENT_URL=https://uprise.example.com
SITE_URL=https://uprise.example.com

# ─── DATABASE CONFIGURATION ───────────────────────────────────────────────────
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL=postgresql://uprise_db_user:secure_password@localhost:5432/uprise_production_db?schema=public

# ─── JWT KEY PAIRS (MUST NOT BE DEFAULT STRINGS IN PRODUCTION) ───────────────
JWT_ACCESS_SECRET=generate_strong_64_character_hex_hash_access
JWT_REFRESH_SECRET=generate_strong_64_character_hex_hash_refresh

# ─── STORAGE CONFIGURATION (CLOUDINARY) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=cloudinary_cloud_name
CLOUDINARY_API_KEY=cloudinary_api_key
CLOUDINARY_API_SECRET=cloudinary_api_secret

# ─── ERROR TRACKING (SENTRY) ──────────────────────────────────────────────────
SENTRY_DSN=https://sentry_key@sentry_host/sentry_project_id
