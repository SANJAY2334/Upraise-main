generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  DISCUSSION
  PROPOSAL_SENT
  CONVERTED
  CLOSED
}

enum MediaResourceType {
  image
  video
  raw
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  isActive     Boolean    @default(true)
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([roleId])
  @@map("users")
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

model FounderProfile {
  id                   String              @id @default(cuid())
  name                 String
  title                String
  biography            String
  leadershipPhilosophy String
  industriesServed     String[]
  strategicExpertise   String[]
  achievements         String[]
  companiesWorkedWith  String[]
  clientImpact         String
  professionalSummary  String
  portraitMediaId      String?
  portraitMedia        MediaAsset?         @relation("FounderPortrait", fields: [portraitMediaId], references: [id])
  timeline             FounderTimeline[]
  highlights           FounderHighlight[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([portraitMediaId])
  @@map("founder_profile")
}

model FounderTimeline {
  id        String         @id @default(cuid())
  year      String
  title     String
  detail    String
  sortOrder Int            @default(0)
  founderId String
  founder   FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  @@index([founderId])
  @@map("founder_timeline")
}

model FounderHighlight {
  id        String         @id @default(cuid())
  label     String
  value     String
  sortOrder Int            @default(0)
  founderId String
  founder   FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  @@index([founderId])
  @@map("founder_highlights")
}

model Service {
  id                 String      @id @default(cuid())
  title              String
  slug               String      @unique
  description        String
  deliverables       String[]
  benefits           String[]
  successStories     String[]
  relatedCaseStudies CaseStudy[] @relation("ServiceCaseStudies")
  isPublished        Boolean     @default(false)
  sortOrder          Int         @default(0)
  seoSettingId       String?
  seoSetting         SeoSetting? @relation(fields: [seoSettingId], references: [id])
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([seoSettingId])
  @@map("services")
}

model Project {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  category    String
  clientName  String
  story       String
  results     String[]
  media       MediaAsset[] @relation("ProjectMedia")
  isFeatured  Boolean      @default(false)
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("projects")
}

model CaseStudy {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  category    String
  clientName  String
  challenge   String
  strategy    String
  execution   String
  results     String[]
  metrics     Json
  media       MediaAsset[] @relation("CaseStudyMedia")
  services    Service[]    @relation("ServiceCaseStudies")
  isFeatured  Boolean      @default(false)
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("case_studies")
}

model Client {
  id            String      @id @default(cuid())
  name          String
  industry      String
  website       String?
  logoMediaId   String?
  logoMedia     MediaAsset? @relation("ClientLogo", fields: [logoMediaId], references: [id])
  successStory  String?
  partnership   String?
  isPublished   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([logoMediaId])
  @@map("clients")
}

model BlogCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  blogs       Blog[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_categories")
}

model BlogTag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  blogs     Blog[]
  createdAt DateTime @default(now())

  @@map("blog_tags")
}

model Blog {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  excerpt        String
  content        String
  readTime       String
  authorName     String
  categoryId     String
  category       BlogCategory @relation(fields: [categoryId], references: [id])
  tags           BlogTag[]
  featuredImageId String?
  featuredImage  MediaAsset?  @relation("BlogFeaturedImage", fields: [featuredImageId], references: [id])
  seoSettingId   String?
  seoSetting     SeoSetting?  @relation(fields: [seoSettingId], references: [id])
  isFeatured     Boolean      @default(false)
  isPublished    Boolean      @default(false)
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([categoryId])
  @@index([featuredImageId])
  @@index([seoSettingId])
  @@map("blogs")
}

model Testimonial {
  id          String   @id @default(cuid())
  quote       String
  name        String
  title       String?
  company     String?
  rating      Int      @default(5)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

model MediaAsset {
  id                 String             @id @default(cuid())
  publicId           String             @unique
  url                String
  secureUrl          String?
  resourceType       String
  format             String?
  bytes              Int?
  width              Int?
  height             Int?
  duration           Float?
  alt                String?
  caption            String?
  folder             String?
  optimizedUrl       String?
  thumbnailUrl       String?
  founderPortraits   FounderProfile[]   @relation("FounderPortrait")
  clientLogos        Client[]           @relation("ClientLogo")
  projectMedia       Project[]          @relation("ProjectMedia")
  caseStudyMedia     CaseStudy[]        @relation("CaseStudyMedia")
  blogFeaturedImages Blog[]             @relation("BlogFeaturedImage")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("media_assets")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  interest  String
  message   String
  consent   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  lead      Lead?
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Lead {
  id               String          @id @default(cuid())
  name             String
  email            String
  phone            String?
  company          String?
  source           String
  interest         String
  status           LeadStatus      @default(NEW)
  notes            String?
  contactMessageId String?         @unique
  contactMessage   ContactMessage? @relation(fields: [contactMessageId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@map("leads")
}

model SeoSetting {
  id              String    @id @default(cuid())
  route           String    @unique
  title           String
  description     String
  canonicalUrl    String?
  openGraphTitle  String?
  openGraphImage  String?
  twitterTitle    String?
  robots          String    @default("index,follow")
  structuredData  Json?
  services        Service[]
  blogs           Blog[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("seo_settings")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model AnalyticsSetting {
  id           String   @id @default(cuid())
  provider     String
  trackingId   String?
  isEnabled    Boolean  @default(false)
  consentGroup String   @default("analytics")
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("analytics_settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}
