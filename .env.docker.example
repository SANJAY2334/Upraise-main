# ─── APPLICATION ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── URLS ──────────────────────────────────────────────────────────────────────
# Set CLIENT_URL to your frontend domain (Vercel URL or custom domain)
CLIENT_URL=https://uprise.example.com
SITE_URL=https://uprise.example.com

# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://uprise_db_user:REPLACE_WITH_STRONG_PASSWORD@database:5432/uprise_production_db?schema=public
POSTGRES_USER=uprise_db_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=uprise_production_db

# ─── JWT SECRETS (must be unique 64+ char hex strings in production) ───────────
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_64_CHAR_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_64_CHAR_HEX_STRING

# ─── CLOUDINARY ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SENTRY (optional - error tracking) ────────────────────────────────────────
SENTRY_DSN=https://your_key@your_host/your_project_id
